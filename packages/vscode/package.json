{
  "name": "mermaid-lint-vscode",
  "displayName": "Mermaid Lint",
  "description": "Live Mermaid diagram validation — inline squiggles, hover, and quick-fixes for .md and .mmd files.",
  "version": "0.11.1",
  "private": true,
  "license": "MIT",
  "publisher": "mermaid-lint",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/jasonworden/mermaid-lint.git",
    "directory": "packages/vscode"
  },
  "bugs": "https://github.com/jasonworden/mermaid-lint/issues",
  "homepage": "https://github.com/jasonworden/mermaid-lint/tree/main/packages/vscode#readme",
  "keywords": [
    "mermaid",
    "diagram",
    "lint",
    "linter",
    "markdown",
    "mmd",
    "validation"
  ],
  "type": "module",
  "engines": {
    "node": ">=20",
    "vscode": "^1.85.0"
  },
  "categories": ["Linters"],
  "main": "./dist/extension.cjs",
  "files": ["dist"],
  "activationEvents": ["onLanguage:markdown", "onLanguage:mermaid"],
  "contributes": {
    "languages": [
      {
        "id": "mermaid",
        "aliases": ["Mermaid"],
        "extensions": [".mmd"]
      }
    ],
    "commands": [
      {
        "command": "mermaidLint.lintAllOpen",
        "title": "Mermaid Lint: Re-lint open documents"
      }
    ],
    "configuration": {
      "title": "Mermaid Lint",
      "properties": {
        "mermaidLint.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable Mermaid diagram validation."
        },
        "mermaidLint.delay": {
          "type": "number",
          "default": 300,
          "description": "Debounce delay (ms) before validating after a change."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc --noEmit && node esbuild.mjs",
    "test:e2e": "node esbuild.mjs && node e2e/runTest.cjs",
    "package": "bash scripts/package-vsix.sh"
  },
  "dependencies": {
    "@mermaid-lint/core": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.24.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.6"
  }
}

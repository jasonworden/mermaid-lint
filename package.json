{
  "name": "mermaid-lint",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.34.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "pretest": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "bench": "node scripts/bench-semantic.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs}": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "typescript": "^5.0.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
}
